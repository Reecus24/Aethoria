# Environment variables for docker-compose
# Kopiere diese Datei zu .env und fülle die Werte aus

# MongoDB Root Password (für Admin-Zugriff)
MONGO_ROOT_PASSWORD=dein_sicheres_mongodb_passwort_hier

# JWT Secret (generiere einen sicheren Key)
# Nutze: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=generiere_einen_sicheren_random_key_hier

# Frontend Backend URL (deine Domain oder Server-IP)
FRONTEND_BACKEND_URL=https://deine-domain.de
# ODER: FRONTEND_BACKEND_URL=http://deine-server-ip
